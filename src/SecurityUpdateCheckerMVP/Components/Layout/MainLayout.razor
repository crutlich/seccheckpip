@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.subtitle1" Class="ml-2" Style="font-weight:600;">ПАТЧ-СКАН</MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Icon="@Icons.Material.Filled.Shield">Методика ФСТЭК</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4 pt-6">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    Произошла необработанная ошибка.
    <a href="" class="reload">Перезагрузить</a>
    <a class="dismiss">X</a>
</div>

@code {
    private bool _drawerOpen = true;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1565C0",
            Secondary = "#7B1FA2",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            AppbarBackground = "#1565C0",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#424242",
            TextPrimary = "#212121",
            TextSecondary = "#757575",
            ActionDefault = "#757575",
            Success = "#2E7D32",
            Warning = "#F57F17",
            Error = "#C62828",
            Info = "#1565C0",
            Divider = "rgba(0,0,0,0.12)",
            LinesDefault = "rgba(0,0,0,0.12)",
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography() { FontFamily = new[] { "Inter", "sans-serif" } }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "8px"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
